# Application
APP_NAME=CodeSentinel AI
APP_ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./codesentinel.db

# GitHub
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_API_TIMEOUT=15.0

# Groq AI
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=openai/gpt-oss-120b
GROQ_API_TIMEOUT=30.0
GROQ_MAX_TOKENS=4096
GROQ_TEMPERATURE=0.2

# Review Engine Tuning
MAX_DIFF_CHARS_PER_FILE=3000
MAX_FILES_PER_REVIEW=15

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/codesentinel.log

# CORS
ALLOWED_ORIGINS=http://localhost:3000